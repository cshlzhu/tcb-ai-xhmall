.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #bfbfbf;
}

/* 地址列表 */
.address-list {
  padding: 20rpx;
}

/* 地址卡片 */
.address-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.address-card.is-default {
  border-left: 6rpx solid #6A5ACD;
}

.card-main {
  padding: 28rpx 28rpx 12rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-info {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.phone {
  font-size: 26rpx;
  color: #7B7B8B;
}

.default-tag {
  background: #FFF7EC;
  border: 1rpx solid #FFD6A5;
  border-radius: 8rpx;
  padding: 4rpx 16rpx;
}

.default-tag text {
  font-size: 22rpx;
  color: #FF6B35;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 10rpx;
}

.region {
  font-size: 28rpx;
  color: #3A3A4A;
}

.detail {
  font-size: 28rpx;
  color: #1A1A2E;
  line-height: 1.5;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
}

.create-time {
  font-size: 22rpx;
  color: #bfbfbf;
}

/* 卡片操作区 */
.card-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  font-size: 24rpx;
}

.action-btn.set-default {
  color: #6A5ACD;
}

.action-btn.edit {
  color: #4A90D9;
}

.action-btn.delete {
  color: #E03A3A;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}
